// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PaymentStatus {
  PAGO
  PENDENTE
}

enum PaymentMethod {
  DINHEIRO
  CARTAO
  PIX
  TRANSFERENCIA
  BANCO
  OUTRO
}

enum ExpenseStatus {
  PAGO
  PENDENTE
}

enum ExpenseCategory {
  ALUGUEL
  PROFESSORES
  MATERIAL
  OUTROS
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Student {
  id              String    @id @default(cuid())
  fullName        String
  birthDate       DateTime?
  cpf             String?   @unique
  studentPhone    String?
  address         String?
  motherName      String?
  motherPhone     String?
  fatherName      String?
  fatherPhone     String?
  category        String?
  primaryPosition String?
  photoUrl        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  payments        Payment[]

  @@index([fullName])
}

model Payment {
  id             String        @id @default(cuid())
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  referenceMonth Int
  referenceYear  Int
  amount         Decimal
  paymentMethod  PaymentMethod @default(PIX)
  paymentDate    DateTime?
  status         PaymentStatus @default(PENDENTE)
  note           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([studentId, referenceMonth, referenceYear])
  @@index([referenceYear, referenceMonth])
  @@index([status])
}

model Expense {
  id          String          @id @default(cuid())
  description String
  category    ExpenseCategory
  amount      Decimal
  dueDate     DateTime
  paymentDate DateTime?
  status      ExpenseStatus   @default(PENDENTE)
  recurring   Boolean         @default(false)
  note        String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([dueDate])
  @@index([status])
}
